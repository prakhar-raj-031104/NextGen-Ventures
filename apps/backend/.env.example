# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"          # development | test | production
PORT=4000                       # Port the API listens on

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required, no default in production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGIN="http://localhost:5173"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# General API: max requests per window (milliseconds) per IP
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX=300              # 300 req / window

# Lead form: stricter limit to prevent spam submissions
LEAD_RATE_LIMIT_WINDOW_MS=3600000   # 1 hour
LEAD_RATE_LIMIT_MAX=10              # 10 submissions / hour per IP
