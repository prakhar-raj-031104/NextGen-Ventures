# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"          # development | test | production
PORT=4000                       # Port the API listens on

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required, no default in production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGIN="http://localhost:5173"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# General API: max requests per window (milliseconds) per IP
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX=300              # 300 req / window

# Lead form: stricter limit to prevent spam submissions
LEAD_RATE_LIMIT_WINDOW_MS=3600000   # 1 hour
LEAD_RATE_LIMIT_MAX=10              # 10 submissions / hour per IP

# ─── Client Portal Authentication ──────────────────────────────────────────────
# Secret used to sign client portal session tokens (HMAC-SHA256).
# MUST be set to a strong, unique value in production (>= 16 chars).
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_TOKEN_TTL_HOURS=168            # Session lifetime in hours (default 7 days)

# ─── Admin Control Panel ───────────────────────────────────────────────────────
ADMIN_PASSWORD="nextgen@2024"       # Owner password for the /admin control panel
ADMIN_TOKEN_TTL_HOURS=12            # Admin session lifetime in hours
